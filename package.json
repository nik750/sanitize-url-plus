{
  "name": "sanitize-url-plus",
  "version": "1.0.0",
  "description": "A comprehensive, zero-dependency URL sanitization library covering all known URL-based attack vectors including XSS, SSRF, open redirect, credential injection, homograph attacks, and more.",
  "author": "NiUnit",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",s
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run build && npm run test"
  },
  "keywords": [
    "url",
    "sanitize",
    "sanitization",
    "security",
    "xss",
    "ssrf",
    "open-redirect",
    "url-validation",
    "url-sanitizer",
    "csrf",
    "injection",
    "homograph",
    "phishing",
    "typescript"
  ],
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/sanitize-url-plus.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/sanitize-url-plus/issues"
  },
  "homepage": "https://github.com/your-org/sanitize-url-plus#readme"
}
